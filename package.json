{
  "name": "pinia-colada-plugin-normalizer",
  "type": "module",
  "version": "0.1.2",
  "description": "Normalized entity caching plugin for Pinia Colada",
  "author": {
    "name": "Danny Devs"
  },
  "license": "MIT",
  "homepage": "https://github.com/Danny-Devs/pinia-colada-plugin-normalizer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Danny-Devs/pinia-colada-plugin-normalizer.git"
  },
  "bugs": {
    "url": "https://github.com/Danny-Devs/pinia-colada-plugin-normalizer/issues"
  },
  "keywords": [
    "pinia",
    "pinia-colada",
    "pinia-colada-plugin",
    "normalization",
    "entity",
    "cache",
    "query",
    "real-time"
  ],
  "sideEffects": false,
  "exports": "./dist/index.mjs",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "cd playground && npx vite",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pinia/colada": ">=1.0.0",
    "pinia": ">=2.1.0",
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@pinia/colada": "^1.0.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "pinia": "^2.3.0",
    "tsdown": "^0.21.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0"
  }
}
